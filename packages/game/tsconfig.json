{
  "compilerOptions": {
    "composite": false,
    "declarationDir": "dist",
    "incremental": false,
    "jsx": "react-jsxdev",
    "lib": ["DOM", "DOM.Iterable", "ESNext"],
    "module": "esnext",
    "moduleResolution": "bundler",
    "outDir": "dist",
    "rootDir": ".",
    "sourceRoot": "src",
    "types": ["@types/node"]
  },
  "exclude": ["./.cache/", "./.tests/"],
  "extends": "quisido/tsconfig.json",
  "include": [
    "**/*.json",
    "**/*.ts",
    "**/*.tsx",
    "**/*.webmanifest"
  ]
}
