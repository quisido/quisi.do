{
  "compilerOptions": {
    "declarationDir": "dist",
    "jsx": "react-jsxdev",
    "lib": [
      "DOM",
      "DOM.Iterable",
      "ESNext"
    ],
    "module": "esnext",
    "moduleResolution": "bundler",
    "outDir": "dist",
    "rootDir": ".",
    "sourceRoot": "src",
    "types": [
      "@types/node"
    ]
  },
  "exclude": [
    "./.cache/",
    "./.tests/"
  ],
  "extends": "quisido/tsconfig.json",
  "include": [
    "**/*.json",
    "**/*.ts",
    "**/*.tsx",
    "**/*.webmanifest"
  ],
  "references": [
    {
      "path": "../fmrs/tsconfig.build.json"
    }
  ]
}
