{
  "compilerOptions": {
    "composite": false,
    "declaration": false,
    "declarationDir": "dist",
    "declarationMap": false,
    "importHelpers": true,
    "incremental": false,
    "inlineSourceMap": false,
    "inlineSources": false,
    "isolatedDeclarations": false,
    "module": "esnext",
    "moduleResolution": "bundler",
    "noPropertyAccessFromIndexSignature": true,
    "outDir": "dist",
    "rootDir": ".",
    "sourceRoot": "src"
  },
  "exclude": [".cache/", ".tests/", ".wrangler/", "dist/"],
  "extends": "quisido/tsconfig.json",
  "include": ["**/*.ts"]
}
