{
  "extends": "./tsconfig.json",
  "include": [
    "src/**/*.ts",
    "src/**/*.tsx"
  ],
  "exclude": [
    ".vscode/",
    ".wrangler/",
    "_site/",
    "scripts/",
    "src/**/*.e2e.ts",
    "src/**/*.test.ts",
    "src/**/*.test.tsx",
    "src/design-systems/core-test/",
    "src/*.test.ts",
    "src/*.test.tsx",
    "src/test/",
    ".*.json",
    "*.config.*",
    "lighthouse.*",
    "tsconfig.*"
  ],
  "compilerOptions": {
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "noEmit": true,
    "rootDir": "src",
    "sourceMap": true,
    "sourceRoot": "https://github.com/quisido/quisi.do/raw/main/packages/saas/src/",
    "target": "es2023",
    "tsBuildInfoFile": ".cache/tsconfig.build.tsbuildinfo"
  }
}
