{
  "compilerOptions": {
    "declarationDir": "dist",
    "noEmit": true,
    "rootDir": ".",
    // Necessary for `quisi.config.ts` to export top-level values.
    "verbatimModuleSyntax": false
  },
  "exclude": [".cache/", ".tests/"],
  "extends": "quisi/tsconfig.json",
  "include": ["**/*", "**/*.json", "**/.*", "**/.*.json"],
}
