{
  "compilerOptions": {
    "declarationDir": "dist",
    "generateCpuProfile": ".cache/tsconfig.cpuprofile",
    "noEmit": false,
    "outDir": "dist",
    "rootDir": "src",
    "skipLibCheck": true,
    "tsBuildInfoFile": ".cache/tsconfig.tsbuildinfo"
  },
  "exclude": [
    ".cache/",
    ".tests/"
  ],
  "extends": "./tsconfig.json",
  "include": [
    "src/",
  ]
}
