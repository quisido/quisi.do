{
  "$schema": "https://developer.microsoft.com/json-schemas/api-extractor/v7/api-extractor.schema.json",
  "apiReport": {
    "enabled": true,
    "includeForgottenExports": true,
    "reportFileName": "<unscopedPackageName>.api.md",
    "reportFolder": "<projectFolder>/etc/",
    "reportTempFolder": "<projectFolder>/.cache/api-extractor/",
    "reportVariants": ["complete"]
  },
  "bundledPackages": [],
  "compiler": {
    "skipLibCheck": false,
    "tsconfigFilePath": "<projectFolder>/tsconfig.build.json"
  },
  "docModel": {
    "apiJsonFilePath": "<projectFolder>/.tests/api-extractor/<unscopedPackageName>.api.json",
    "enabled": true,
    "includeForgottenExports": true
  },
  "dtsRollup": {
    "alphaTrimmedFilePath": "",
    "betaTrimmedFilePath": "",
    "enabled": true,
    "omitTrimmingComments": false,
    "publicTrimmedFilePath": "",
    "untrimmedFilePath": "<projectFolder>/.tests/api-extractor/<unscopedPackageName>.d.ts"
  },
  "enumMemberOrder": "by-name",
  "mainEntryPointFilePath": "<projectFolder>/dist/index.d.ts",
  "messages": {
    "compilerMessageReporting": {
      "default": {
        "addToApiReportFile": true,
        "logLevel": "error"
      }
    },
    "extractorMessageReporting": {
      "default": {
        "addToApiReportFile": true,
        "logLevel": "error"
      }
    },
    "tsdocMessageReporting": {
      "default": {
        "addToApiReportFile": true,
        "logLevel": "error"
      }
    }
  },
  "newlineKind": "lf",
  "testMode": false,
  "tsdocMetadata": {
    "enabled": true,
    "tsdocMetadataFilePath": "<projectFolder>/dist/tsdoc-metadata.json"
  }
}
