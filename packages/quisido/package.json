{
  "name": "quisido",
  "version": "0.0.3",
  "author": "quisi.do <quisido@quisi.do>",
  "description": "all-in-one",
  "homepage": "https://github.com/quisido/quisi.do/tree/main/packages/quisido#readme",
  "license": "MIT",
  "main": "./dist/index.js",
  "type": "module",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsc --project tsconfig.build.json",
    "start": "tsc --project tsconfig.build.json --watch",
    "test": "quisido test",
    "clean": "rm -rf .cache .tests dist node_modules",
    "eslint": "quisido eslint",
    "publint": "quisido publint",
    "vitest": "vitest",
    "vitest:run": "vitest run",
    "vitest:watch": "vitest watch"
  },
  "bin": {
    "quisido": "./dist/cli.js"
  },
  "bugs": {
    "email": "quisido@quisi.do",
    "url": "https://github.com/quisido/quisi.do/issues"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./.attw.json": {
      "default": "./.attw.json"
    },
    "./tsconfig.json": {
      "default": "./src/tsconfig.json"
    },
    "./vitest-setup-file.js": {
      "types": "./dist/features/vitest/setup-file.d.ts",
      "default": "./dist/features/vitest/setup-file.js"
    }
  },
  "keywords": [
    "build-tool",
    "cli",
    "eslint",
    "typescript",
    "vite",
    "vitest"
  ],
  "funding": {
    "type": "individual",
    "url": "https://github.com/sponsors/quisido"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "repository": {
    "directory": "packages/quisido",
    "type": "git",
    "url": "git+https://github.com/quisido/quisi.do.git"
  },
  "dependencies": {
    "@arethetypeswrong/cli": "^0.18.4",
    "@eslint/config-helpers": "^0.6.0",
    "@eslint/js": "^10.0.1",
    "@eslint/json": "^2.0.0",
    "@microsoft/eslint-formatter-sarif": "^3.1.0",
    "@typescript-eslint/eslint-plugin": "^8.62.0",
    "@typescript-eslint/parser": "^8.46.3",
    "eslint": ">=10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-json-schema-validator": "^6.2.0",
    "eslint-plugin-jsonc": "^3.2.0",
    "eslint-plugin-prettier": "^5.5.6",
    "eslint-plugin-sort-keys-custom-order": "^3.0.2",
    "jsonc-eslint-parser": "^3.1.0",
    "prettier": "^3.8.4",
    "publint": "^0.3.21",
    "typescript-eslint": "^8.62.0",
    "vite": "^8.0.16",
    "yaml-eslint-parser": "^2.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^26.0.0",
    "@vitest/coverage-istanbul": "^4.0.7",
    "typescript": "^6.0.3",
    "vitest": "^4.1.0"
  },
  "peerDependencies": {
    "@vitest/coverage-istanbul": ">=4.0.0",
    "typescript": ">=5.0.0",
    "vitest": ">=4.0.0"
  },
  "peerDependenciesMeta": {
    "@vitest/coverage-istanbul": {
      "optional": true
    },
    "vitest": {
      "optional": true
    }
  }
}
