{
  "compilerOptions": {
    "paths": {
      /**
       * eslint-plugin-sort-keys-custom-order 3.0.2 publishes its declaration
       * file here, despite advertising ./dist/index.d.ts in package.json.
       */
      "eslint-plugin-sort-keys-custom-order": [
        "./node_modules/eslint-plugin-sort-keys-custom-order/dist/src/index.d.ts"
      ]
    },
    "rootDir": "."
  },
  "exclude": [".cache/", ".tests/"],
  "extends": "./src/tsconfig.json",
  "include": ["**/*", "**/*.json", "**/.*", "**/.*.json"]
}
