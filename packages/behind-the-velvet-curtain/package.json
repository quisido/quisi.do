  "type": "module",
  "scripts": {
    "build": "tsc --skipLibCheck && vite build",
    "start": "vite",
    "test": "quisido test && npm run vitest:run && npm run vitest:browser",
    "clean": "rimraf .cache .tests dist node_modules",
    "eslint": "quisido eslint",
    "serve": "serve dist",
    "tsc": "tsc --skipLibCheck",
    "vitest": "quisido vitest",
    "vitest:browser": "vitest run --project browser",
    "vitest:run": "vitest run --project unit"
  },
