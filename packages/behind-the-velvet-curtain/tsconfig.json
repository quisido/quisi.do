{
  "compilerOptions": {
    "declarationDir": "dist",
    "lib": [
      "DOM",
      "DOM.Iterable",
      "ESNext"
    ],
    "module": "esnext",
    "moduleResolution": "bundler",
    "outDir": "dist",
    "rootDir": ".",
    "sourceRoot": "src",
    "types": [
      "@types/node",
      "vite/client",
      "vite-plugin-pwa/client"
    ],
    "paths": {
      "quisido": [
        "../quisido/src/index.ts"
      ]
    }
  },
  "exclude": [
    "./.cache/",
    "./.tests/"
  ],
  "extends": "quisido/tsconfig.json",
  "include": [
    "**/*.json",
    "**/*.ts",
    "**/*.tsx",
    "**/*.webmanifest"
  ],
  "references": [
    {
      "path": "../quisido/tsconfig.build.json"
    }
  ]
}
