{
  "compilerOptions": {
    "composite": false,
    "declarationDir": "dist",
    "incremental": false,
    "lib": ["DOM", "DOM.Iterable", "ESNext"],
    "module": "esnext",
    "moduleResolution": "bundler",
    "outDir": "dist",
    "rootDir": ".",
    "sourceRoot": "src",
    "types": ["@types/node", "vite/client", "vite-plugin-pwa/client"]
  },
  "exclude": ["./.cache/", "./.tests/"],
  "extends": "quisido/tsconfig.json",
  "include": ["**/*.json", "**/*.ts", "**/*.tsx", "**/*.webmanifest"]
}
