{
  "extends": ["../../.hintrc"],
  "hints": {
    "axe/aria": [
      "error",
      // https://webhint.io/docs/user-guide/hints/hint-axe/aria/#additional-rules-off-by-default
      [
        "aria-allowed-role",
        "aria-dialog-name",
        "aria-text",
        "aria-treeitem-name",
        "presentation-role-conflict"
      ]
    ],
    "axe/keyboard": [
      "error",
      // https://webhint.io/docs/user-guide/hints/hint-axe/keyboard/#additional-rules-off-by-default
      {
        "accesskeys": "error",
        "focus-order-semantics": "error",
        "region": "error",
        "skip-link": "error",
        "tabindex": "error"
      }
    ],
    "doctype": "error",
    "html-checker": [
      "error",
      {
        "details": true
      }
    ]
  }
}
