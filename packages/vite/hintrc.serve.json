{
  // "$schema": "https://raw.githubusercontent.com/webhintio/hint/main/packages/hint/src/lib/config/config-schema.json",

  "extends": ["../../.hintrc"],

  "hints": {
    // Technical debt: Re-enable this when the theme is finalized.
    "axe/color": "off",

    "axe/keyboard": [
      "error",
      // https://webhint.io/docs/user-guide/hints/hint-axe/keyboard/#additional-rules-off-by-default
      {
        "accesskeys": "error",
        "focus-order-semantics": "error",
        "region": "error",
        "skip-link": "error",
        "tabindex": "error"
      }
    ],

    /**
     * Technical debt: Re-enable this when `api-js.mixpanel.com` is blocked.
     * axe/text-alternatives: Element has no title attribute
     * <img src="https://api-js.mixpanel.com/track/..." />
     */
    "axe/text-alternatives": "off",

    /**
     *   Technical debt: Re-enable this after debugging why the hint options in
     * `~/.hintrc` are ignored.
     */
    "compat-api/css": "off",

    // Technical debt: Re-enable these when the animation is optimized.
    "detect-css-reflows/composite": "off",
    "detect-css-reflows/paint": "off",
    "doctype": "error",
    "html-checker": [
      "error",
      {
        "details": true
      }
    ],

    // "No valid configuration for Cloudinary found. Hint could not run."
    "image-optimization-cloudinary": "off",

    // We don't use SSL on localhost.
    "ssllabs": "off"
  },

  "ignoredUrls": [
    {
      "domain": "^(?!localhost:3000$).*",
      "hints": [
        "content-type",
        "doctype",
        "http-cache",
        "http-compression",
        "no-disallowed-headers",
        "no-html-only-headers",
        "no-http-redirects",
        "sri",
        "strict-transport-security",
        "validate-set-cookie-header",
        "x-content-type-options"
      ]
    }
  ]
}
