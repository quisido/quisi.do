{
  // "$schema": "https://raw.githubusercontent.com/webhintio/hint/main/packages/hint/src/lib/config/config-schema.json",

  "extends": ["../../.hintrc"],

  "hints": {
    // Technical debt: Re-enable these when the animation is optimized.
    "detect-css-reflows/composite": "off",
    "detect-css-reflows/paint": "off"
  },

  /**
   * axe/text-alternatives: Element has no title attribute
   * <img src="https://api-js.mixpanel.com/track/..." />
   */

  "ignoredUrls": [
    {
      "domain": "^(?!localhost:3000$).*",
      "hints": [
        "content-type",
        "http-cache",
        "http-compression",
        "no-disallowed-headers",
        "no-html-only-headers",
        "no-http-redirects",
        "sri",
        "strict-transport-security",
        "validate-set-cookie-header",
        "x-content-type-options"
      ]
    }
  ]
}
