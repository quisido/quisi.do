{
  "compilerOptions": {
    "composite": false,
    "declarationDir": "_site",
    "incremental": false,
    "jsx": "preserve",
    "lib": ["DOM", "DOM.Iterable", "ESNext"],
    "module": "esnext",
    "moduleResolution": "bundler",
    "outDir": "_site",
    "rootDir": ".",
    "sourceRoot": "src"
  },
  "exclude": [
    "src/design-systems/core-test/*.ts",
    "src/design-systems/core-test/*.tsx"
  ],
  "extends": "quisido/tsconfig.json",
  "include": [
    "**/.*.json",
    "**/.*.ts",
    "**/*.json",
    "**/*.ts",
    "**/*.tsx",
    "**/*.webmanifest"
  ]
}
