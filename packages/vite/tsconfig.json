{
  "compilerOptions": {
    "composite": false,
    // The declaration directory is required, else Vitest will throw an error.
    "declarationDir": "_site",
    "incremental": false,
    "jsx": "preserve",
    "lib": ["DOM", "DOM.Iterable", "ESNext"],
    "module": "esnext",
    "moduleResolution": "bundler",
    "outDir": "_site",
    "rootDir": ".",
    "sourceRoot": "src"
  },
  "exclude": [],
  "extends": "quisido/tsconfig.json",
  "include": [
    "**/.*.json",
    "**/.*.ts",
    "**/*.json",
    "**/*.ts",
    "**/*.tsx",
    "**/*.webmanifest"
  ]
}
