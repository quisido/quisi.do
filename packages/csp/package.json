{
  "name": "@quisido/csp",
  "version": "1.0.0",
  "license": "UNLICENSED",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "exit 0",
    "start": "npm run dev",
    "test": "quisido test",
    "clean": "rimraf .cache .tests .wrangler dist node_modules",
    "dev": "wrangler dev --persist-to ../../.wrangler/state",
    "eslint": "quisido eslint",
    "local:drop": "wrangler d1 execute csp-dev --file=./sql/drop.sql --local --persist-to ../../.wrangler/state",
    "local:init": "npm run local:init:projects && npm run local:init:keys && npm run local:init:reports",
    "local:init:keys": "wrangler d1 execute csp-dev --file=./sql/keys.sql --local --persist-to ../../.wrangler/state",
    "local:init:projects": "wrangler d1 execute csp-dev --file=./sql/projects.sql --local --persist-to ../../.wrangler/state",
    "local:init:reports": "wrangler d1 execute csp-dev --file=./sql/reports.sql --local --persist-to ../../.wrangler/state",
    "local:reinit": "npm run local:drop && npm run local:init",
    "login": "wrangler login",
    "production:deploy:dry-run": "wrangler deploy src/index.ts --dry-run --env production --outdir dist",
    "production:init": "npm run production:init:projects && npm run production:init:reports",
    "production:init:projects": "wrangler d1 execute csp --env production --file=./sql/projects.sql --remote",
    "production:init:reports": "wrangler d1 execute csp --env production --file=./sql/reports.sql --remote",
    "staging:deploy": "wrangler deploy src/index.ts --env staging --outdir dist --remote",
    "staging:deploy:dry-run": "wrangler deploy src/index.ts --dry-run --env staging --outdir dist --remote",
    "staging:init": "npm run staging:init:projects && npm run staging:init:reports",
    "staging:init:projects": "wrangler d1 execute csp-staging --env staging --file=./sql/projects.sql --remote",
    "staging:init:reports": "wrangler d1 execute csp-staging --env staging --file=./sql/reports.sql --remote",
    "vitest": "vitest",
    "vitest:run": "vitest run",
    "vitest:watch": "vitest watch",
    "whoami": "wrangler whoami"
  },
  "keywords": [
    "cloudflare-workers",
    "content-security-policy",
    "csp",
    "reporting",
    "security",
    "serverless"
  ],
  "funding": {
    "type": "individual",
    "url": "https://github.com/sponsors/quisido"
  },
  "repository": {
    "directory": "packages/csp",
    "type": "git",
    "url": "git+https://github.com/quisido/quisi.do.git"
  },
  "dependencies": {
    "@quisido/csp-shared": "^1.0.1",
    "@quisido/worker": "^1.0.8",
    "cloudflare-utils": "^1.0.4",
    "fmrs": "^3.0.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260624.1",
    "@quisido/worker-test": "^1.0.1",
    "@types/eslint": "^9.6.1",
    "@vitest/ui": "^4.1.9",
    "cloudflare-test-utils": "^1.0.2",
    "concurrently": "^10.0.3",
    "quisido": "^0.0.3",
    "rimraf": "^6.1.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.0",
    "wrangler": "^4.105.0"
  }
}
