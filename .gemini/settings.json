{
  "mcp": {
    "allowed": [
      "chrome-devtools",
      "cloudflare",
      "context7",
      "github",
      "playwright",
      "sentry"
    ]
  },
  "mcpServers": {
    "chrome-devtools": {
      "args": ["chrome-devtools-mcp"],
      "command": "npx"
    },
    "cloudflare": {
      "type": "http",
      "url": "https://mcp.cloudflare.com/sse"
    },
    "context7": {
      "type": "http",
      "url": "https://mcp.context7.com/mcp"
    },
    "github": {
      "type": "http",
      "url": "https://api.githubcopilot.com/mcp/"
    },
    "playwright": {
      "args": [
        "@playwright/mcp",
        "--caps",
        "devtools,vision",
        "--console-level",
        "warning",
        "--headless",
        "--isolated",
        "--sandbox",
        "--storage-state=.cache/playwright-mcp/storage-state.json"
      ],
      "command": "npx"
    },
		"sentry": {
			"type": "http",
			"url": "https://mcp.sentry.dev/mcp"
		}
  }
}
