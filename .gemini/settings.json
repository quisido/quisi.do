{
  "mcp": {
    "allowed": ["chrome-devtools", "sentry"]
  },
  "mcpServers": {
    "cloudflare": {
      "type": "http",
      "url": "https://mcp.cloudflare.com/sse"
    },
    "chrome-devtools": {
      "args": [
        "-y",
        "chrome-devtools-mcp@latest"
      ],
      "command": "npx"
    },
    "context7": {
      "type": "http",
      "url": "https://mcp.context7.com/mcp"
    },
    "github": {
      "type": "http",
      "url": "https://api.githubcopilot.com/mcp/"
    },
    "playwright": {
      "args": [
        "@playwright/mcp@latest",
        "--isolated",
        "--storage-state=playwright/storage-state.json"
      ],
      "command": "npx"
    },
		"sentry": {
			"type": "http",
			"url": "https://mcp.sentry.dev/mcp"
		}
  }
}
