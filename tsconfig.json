{
  "compilerOptions": {
    "declarationDir": "dist",
    "rootDir": "."
  },
  "exclude": [
    ".cache/",
    ".git/",
    ".idea/",
    ".tests/",
    ".wrangler/",
    "dist/",
    "node_modules/",
    "packages/"
  ],
  "extends": "quisido/tsconfig.json",
  "include": [
    "**/.*/**/*.ts",
    "**/.*/**/.*.json",
    "**/.*/**/*.json",
    "**/.*.json",
    "**/*.json",
    "**/*.ts"
  ]
}
