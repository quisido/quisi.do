{
  "compilerOptions": {
    "declarationDir": "dist",
    "generateCpuProfile": ".cache/tsconfig.cpuprofile",
    "rootDir": ".",
    "skipLibCheck": true,
    "tsBuildInfoFile": ".cache/tsconfig.tsbuildinfo"
  },
  "exclude": [
    ".cache/",
    ".git/",
    ".idea/",
    ".tests/",
    ".wrangler/",
    "dist/",
    "node_modules/",
    "packages/"
  ],
  "extends": "quisido/tsconfig.json",
  "include": [
    "**/.*/**/*.ts",
    "**/.*/**/.*.json",
    "**/.*/**/*.json",
    "**/.*.json",
    "**/*.json",
    "**/*.ts"
  ],
  "references": [
    {
      "path": "./packages/authn-shared/tsconfig.json"
    },
    {
      "path": "./packages/cloudflare-test-utils/tsconfig.json"
    },
    {
      "path": "./packages/cloudflare-utils/tsconfig.json"
    },
    {
      "path": "./packages/csp-shared/tsconfig.json"
    },
    {
      "path": "./packages/fmrs/tsconfig.json"
    },
    {
      "path": "./packages/fullstory-react/tsconfig.json"
    },
    {
      "path": "./packages/lazy-i18n/tsconfig.json"
    },
    {
      "path": "./packages/number-format-react/tsconfig.json"
    },
    {
      "path": "./packages/quisido/tsconfig.json"
    },
    {
      "path": "./packages/react-datadog/tsconfig.json"
    },
    {
      "path": "./packages/sentry-react/tsconfig.json"
    },
    {
      "path": "./packages/use-force-update/tsconfig.json"
    },
    {
      "path": "./packages/use-shallow-memo/tsconfig.json"
    },
    {
      "path": "./packages/worker/tsconfig.json"
    },
    {
      "path": "./packages/worker-test/tsconfig.json"
    }
  ]
}
