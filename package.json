{
  "name": "@quisi/do",
  "version": "1.0.0",
  "author": "quisi.do <contact@quisi.do>",
  "description": "quisi.do",
  "homepage": "https://quisi.do/",
  "license": "UNLICENSED",
  "packageManager": "pnpm@10.32.1+sha512.a706938f0e89ac1456b6563eab4edf1d1faf3368d1191fc5c59790e96dc918e4456ab2e67d613de1043d2e8c81f87303e6b40d4ffeca9df15ef1ad567348f2be",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "pnpm run tsc:build && node ./dist/scripts/build.js",
    "start": "pnpm run tsc:build && node ./dist/scripts/start.js",
    "test": "quisido test && pnpm run test:workspaces",
    "authn": "pnpm --filter=./packages/authn start",
    "browserslist:update-db": "browserslist --update-db",
    "clean": "rimraf .cache .tests dist node_modules && pnpm -r --if-present run clean",
    "cloudflare-utils": "pnpm --filter=./packages/cloudflare-utils start",
    "csp": "pnpm --filter=./packages/csp start",
    "dashboard": "pnpm --filter=./packages/dashboard start",
    "eslint": "quisido eslint",
    "eslint-config": "pnpm --filter=./packages/eslint-config start",
    "fmrs": "pnpm --filter=./packages/fmrs start",
    "game": "pnpm --filter=./packages/game start",
    "lighthouse": "pnpm --filter=./packages/vite start",
    "postlighthouse": "pnpm --filter=./packages/vite start",
    "prompt": "quisido-ai",
    "publint": "quisido publint",
    "publish": "node ./dist/scripts/publish.js",
    "quisido": "pnpm --filter=./packages/quisido start",
    "react-datadog": "pnpm --filter=./packages/react-datadog start",
    "test:workspaces": "node ./dist/scripts/test.js",
    "tsc:build": "tsc --project tsconfig.build.json",
    "update": "node ./dist/scripts/update.js",
    "vite": "pnpm --filter=./packages/vite start",
    "vitest": "vitest run",
    "worker": "pnpm --filter=./packages/worker start"
  },
  "bugs": {
    "email": "bugs@quisi.do",
    "url": "https://github.com/quisido/quisi.do/issues"
  },
  "funding": {
    "type": "individual",
    "url": "https://github.com/sponsors/quisido"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/quisido/quisi.do.git"
  },
  "dependencies": {
    "fmrs": "^2.1.1"
  },
  "devDependencies": {
    "@hint/connector-puppeteer": "^2.5.25",
    "@hint/formatter-codeframe": "^3.1.36",
    "@hint/formatter-html": "^4.3.17",
    "@hint/formatter-json": "^3.1.36",
    "@hint/formatter-stylish": "^3.1.36",
    "@hint/formatter-summary": "^3.0.39",
    "@hint/hint-doctype": "^3.3.27",
    "@hint/hint-https-only": "^2.4.27",
    "@hint/hint-meta-theme-color": "^4.0.23",
    "@hint/hint-minified-js": "^2.4.27",
    "@hint/hint-no-broken-links": "^4.2.27",
    "@hint/hint-no-p3p": "^3.3.27",
    "@hint/hint-performance-budget": "^2.4.27",
    "@hint/parser-babel-config": "^2.1.43",
    "@hint/parser-css": "^3.0.39",
    "@hint/parser-html": "^3.1.4",
    "@hint/parser-javascript": "^3.1.25",
    "@hint/parser-jsx": "^1.1.6",
    "@hint/parser-manifest": "^2.3.20",
    "@hint/parser-package-json": "^1.1.43",
    "@hint/parser-sass": "^1.0.31",
    "@hint/parser-typescript": "^1.0.26",
    "@hint/parser-typescript-config": "^2.4.31",
    "@hint/parser-webpack-config": "^2.1.42",
    "@hint/utils-types": "^1.2.1",
    "@types/eslint": "^9.6.1",
    "@types/node": "^24.10.4",
    "@vitest/ui": "^4.0.6",
    "browserslist": "^4.24.5",
    "concurrently": "^9.1.2",
    "hint": "^7.1.13",
    "jiti": "^2.6.1",
    "puppeteer-core": "^24.35.0",
    "quisido": "^0.0.2",
    "rimraf": "^6.1.0",
    "typescript": "^5.8.3",
    "vitest": "^4.0.7"
  },
  "pnpm": {
    "overrides": {
      "@hint/connector-puppeteer>puppeteer-core": ">=22.11.1",
      "eslint-plugin-react-hooks>zod-validation-error": "^4.0.0"
    },
    "onlyBuiltDependencies": [
      "@datadog/native-appsec",
      "@datadog/native-iast-taint-tracking",
      "@datadog/native-metrics",
      "@datadog/pprof",
      "@parcel/watcher",
      "@sentry-internal/node-cpu-profiler",
      "canvas",
      "core-js",
      "cpu-features",
      "dd-trace",
      "esbuild",
      "protobufjs",
      "sharp",
      "ssh2",
      "workerd"
    ]
  }
